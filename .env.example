# =============================================================================
# Anthropic-Bedrock API Proxy — environment template
# =============================================================================
# Copy to .env and fill in. docker-compose.yml reads these via ${VAR}.
# All credentials/secrets MUST be injected here; none are hardcoded in compose.
#
#   cp .env.example .env
#   docker compose --profile anthropic up -d
# =============================================================================

# --- Backend mode: bedrock | openai | anthropic ---
BACKEND_MODE=anthropic

# --- Transparent proxy: relay client x-api-key verbatim to upstream, skip
#     proxy auth (DDB/master key). Only meaningful with anthropic/openai. ---
TRANSPARENT_PROXY=false

# --- Anthropic direct backend (BACKEND_MODE=anthropic only) ---
# Use https://api.anthropic.com for the official endpoint, or point at a
# Claude-compatible gateway of your choice.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# --- OpenAI-compatible backend (BACKEND_MODE=openai only) ---
OPENAI_BASE_URL=
OPENAI_API_KEY=

# --- AWS credentials ---
# Always required (DynamoDB). For BACKEND_MODE=bedrock these also drive the
# boto3 bedrock-runtime client.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Authentication ---
# Master key clients use as x-api-key. REQUIRED.
MASTER_API_KEY=
REQUIRE_API_KEY=true

# --- Web search (Tavily) ---
# Required for the web_search tool. Get one at https://tavily.com
WEB_SEARCH_API_KEY=

# --- PTC / standalone code execution sandbox ---
# Image pulled inside the dind daemon for code execution sandboxes.
PTC_SANDBOX_IMAGE=python:3.11-slim

# --- Server ---
PROXY_PORT=8000
WORKERS=4
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- DynamoDB Local ports (host-side) ---
DDB_PORT=8001
DDB_ADMIN_PORT=8002

# --- Tracing (optional) ---
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=
